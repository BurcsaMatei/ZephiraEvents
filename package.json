{
  "name": "konceptid-base-template",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "prebuild": "npm run gallery:build && node scripts/build-menus-index.mjs",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "type-check": "npm run typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run typecheck && npm run lint --if-present",
    "preview": "next dev -p 3002",
    "gallery:build": "node scripts/build-gallery.mjs",
    "rss:build": "tsx scripts/build-rss.ts",
    "postbuild": "npm run rss:build",
    "check:all": "npm run typecheck && npm run lint",
    "generate:og": "node scripts/generate-og.mjs",
    "optimise:images": "node scripts/optimise-images.mjs",
    "optimise:videos": "node scripts/optimise-videos.mjs",
    "migrate:reviews": "tsx scripts/migrate-reviews.ts"
  },
  "dependencies": {
    "@google-analytics/data": "^5.2.1",
    "@vanilla-extract/css": "^1.17.4",
    "@vanilla-extract/next-plugin": "^2.4.14",
    "framer-motion": "^12.23.12",
    "googleapis": "^171.4.0",
    "next": "^15.5.7",
    "next-pwa": "^5.6.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "recharts": "^3.8.0",
    "yet-another-react-lightbox": "^3.25.0",
    "zod": "^4.0.17"
  },
  "devDependencies": {
    "@types/node": "^20.19.11",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "critters": "^0.0.23",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.5.0",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^3.2.0",
    "prettier": "^3.6.2",
    "puppeteer": "^24.40.0",
    "sharp": "^0.34.5",
    "tsx": "^4.20.5",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=20.0.0"
